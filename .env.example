# =====================================================================
# Community — environment variables
# Copy this file to .env and fill in the values before running compose.
# =====================================================================

# --- General ---------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info                         # trace | debug | info | warn | error
SENTRY_DSN=                            # leave empty to disable Sentry
SENTRY_TRACES_SAMPLE_RATE=0
RELEASE=                               # optional release tag (git sha, version)
APP_DOMAIN=community.meoxa.app         # public domain served by Caddy
APP_URL=https://community.meoxa.app    # full public URL
API_URL=https://community.meoxa.app/api
LETSENCRYPT_EMAIL=admin@meoxa.app        # for Caddy auto-HTTPS

# --- Postgres --------------------------------------------------------
POSTGRES_USER=community
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=community
DATABASE_URL=postgresql://community:change_me_strong_password@postgres:5432/community?schema=public

# --- Redis -----------------------------------------------------------
REDIS_URL=redis://redis:6379

# --- Auth / JWT ------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Encryption key for OAuth tokens stored in DB (32 bytes hex => 64 chars)
TOKEN_ENCRYPTION_KEY=change_me_64_hex_chars_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# --- Frontend (Next.js) ---------------------------------------------
NEXT_PUBLIC_API_URL=https://community.meoxa.app/api

# --- AI assistant (Claude — optional, leave empty to disable AI features) ---
# Used for hashtag suggestions and post rewriting. Get your key at
# https://console.anthropic.com/. Uses claude-opus-4-7 with prompt caching.
ANTHROPIC_API_KEY=

# --- SMTP (optional — leave SMTP_HOST empty to log emails instead) --
# When SMTP_HOST is empty, signup auto-verifies the email (dev-friendly).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Community <no-reply@meoxa.app>

# --- Stripe (optional — leave STRIPE_SECRET_KEY empty to disable billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from your Stripe dashboard (create one product per tier)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# =====================================================================
# Social provider credentials — fill the ones you intend to use
# =====================================================================

# --- LinkedIn (Marketing Developer Platform) ------------------------
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://community.meoxa.app/api/social/linkedin/callback

# --- Meta (Facebook + Instagram via Graph API) ----------------------
# https://developers.facebook.com/apps
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://community.meoxa.app/api/social/meta/callback
META_GRAPH_VERSION=v21.0

# --- TikTok (TikTok for Developers) ---------------------------------
# https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://community.meoxa.app/api/social/tiktok/callback

# --- X / Twitter (OAuth 2.0 with PKCE) ------------------------------
# https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=https://community.meoxa.app/api/social/twitter/callback

# --- Backups (Postgres + uploads) -----------------------------------
# A `backup` service runs in compose and dumps the DB + uploads volume
# to /var/lib/docker/volumes/community_backup-data/_data inside the host.
BACKUP_INTERVAL_SECONDS=86400          # how often to run (default: 24h)
BACKUP_RETENTION_DAYS=14               # delete dumps older than this
BACKUP_INCLUDE_UPLOADS=true            # set to false to skip uploads archive

# --- Bluesky (AT Protocol — connection via app passwords) -----------
# Users connect by entering their handle + an app-password generated at
# https://bsky.app/settings/app-passwords. No client credentials needed;
# only override BLUESKY_PDS_URL if you target a non-default PDS instance.
BLUESKY_PDS_URL=https://bsky.social
