# =====================================================================
# Community — environment variables
# Copy this file to .env and fill in the values before running compose.
# =====================================================================

# --- General ---------------------------------------------------------
NODE_ENV=production
APP_DOMAIN=community.example.com         # public domain served by Caddy
APP_URL=https://community.example.com    # full public URL
API_URL=https://community.example.com/api
LETSENCRYPT_EMAIL=admin@example.com      # for Caddy auto-HTTPS

# --- Postgres --------------------------------------------------------
POSTGRES_USER=community
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=community
DATABASE_URL=postgresql://community:change_me_strong_password@postgres:5432/community?schema=public

# --- Redis -----------------------------------------------------------
REDIS_URL=redis://redis:6379

# --- Auth / JWT ------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Encryption key for OAuth tokens stored in DB (32 bytes hex => 64 chars)
TOKEN_ENCRYPTION_KEY=change_me_64_hex_chars_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# --- Frontend (Next.js) ---------------------------------------------
NEXT_PUBLIC_API_URL=https://community.example.com/api

# --- SMTP (optional — leave SMTP_HOST empty to log emails instead) --
# When SMTP_HOST is empty, signup auto-verifies the email (dev-friendly).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Community <no-reply@example.com>

# =====================================================================
# Social provider credentials — fill the ones you intend to use
# =====================================================================

# --- LinkedIn (Marketing Developer Platform) ------------------------
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://community.example.com/api/social/linkedin/callback

# --- Meta (Facebook + Instagram via Graph API) ----------------------
# https://developers.facebook.com/apps
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://community.example.com/api/social/meta/callback
META_GRAPH_VERSION=v21.0

# --- TikTok (TikTok for Developers) ---------------------------------
# https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://community.example.com/api/social/tiktok/callback

# --- (Optional) X / Twitter -----------------------------------------
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=https://community.example.com/api/social/twitter/callback
