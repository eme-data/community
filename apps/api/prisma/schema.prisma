generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum SubscriptionStatus {
  NONE          // free plan, no Stripe subscription
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum SocialProvider {
  LINKEDIN
  FACEBOOK
  INSTAGRAM
  TIKTOK
  TWITTER
  BLUESKY
  YOUTUBE
}

enum PostStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

model Tenant {
  id                    String              @id @default(cuid())
  slug                  String              @unique
  name                  String
  plan                  Plan                @default(FREE)
  // Onboarding progress for the tenant
  onboardingCompletedAt DateTime?
  onboardingStep        String              @default("welcome") // welcome | verify | connect | first_post | done

  // Approval workflow — when true, EDITOR-created posts go through PENDING_APPROVAL
  // and require an OWNER/ADMIN to approve before scheduling.
  requireApproval       Boolean             @default(false)

  // Brand voice profile — injected into AI prompts so generated content
  // matches the tenant's tone, vocabulary and constraints.
  brandVoice            Json?

  // White-label theming. logoMediaId references a MediaAsset uploaded via
  // the standard /media endpoint; the public /api/media/:id/raw URL is used
  // as the logo <img src>.
  brandName             String?
  primaryColor          String?
  logoMediaId           String?

  // Stripe billing
  stripeCustomerId      String?             @unique
  stripeSubscriptionId  String?             @unique
  stripePriceId         String?
  subscriptionStatus    SubscriptionStatus  @default(NONE)
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean             @default(false)

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  memberships           Membership[]
  accounts              SocialAccount[]
  posts                 Post[]
  mediaAssets           MediaAsset[]
  templates             PostTemplate[]
  webhooks              Webhook[]
  notifications         Notification[]
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  name               String?
  emailVerifiedAt    DateTime?

  // Platform-level super admin — can configure OAuth provider credentials,
  // global settings, etc. Distinct from per-tenant Membership.role.
  isSuperAdmin       Boolean             @default(false)

  // Two-factor (TOTP). Secret is encrypted with TOKEN_ENCRYPTION_KEY.
  totpSecret         String?
  totpEnabledAt      DateTime?

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  memberships        Membership[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  backupCodes        BackupCode[]
}

// Platform-wide OAuth credentials for one social provider. Stored once for
// the whole instance (the SaaS operator), not per-tenant: every client uses
// the same OAuth app the operator registered with each network.
//
// `values` holds key/value pairs (CLIENT_ID, CLIENT_SECRET, REDIRECT_URI…).
// Secrets are AES-256-GCM encrypted; their key names appear in `encryptedKeys`.
//
// At runtime, ProviderEnvService merges this row with process.env (DB wins),
// so an instance with no DB row falls back to the legacy .env-based config.
model ProviderConfig {
  id              String         @id @default(cuid())
  provider        SocialProvider @unique
  values          Json           @default("{}")
  encryptedKeys   String[]       @default([])
  isActive        Boolean        @default(true)
  updatedByUserId String?
  updatedAt       DateTime       @updatedAt
  createdAt       DateTime       @default(now())
}

model BackupCode {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  // sha256 of the raw code — codes are shown to the user once and never stored.
  codeHash   String    @unique
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  // Hashed token (sha256) — the raw token is sent by email and never stored.
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordReset {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model ApiKey {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  // sha256 of the raw key — the raw apk_… key is shown to the user once,
  // never stored in plaintext.
  keyHash         String    @unique
  // 4-char prefix shown to the user for identification (e.g. "apk_abcd…").
  preview         String
  scopes          String[]  @default(["read", "write"])
  createdByUserId String
  expiresAt       DateTime?
  revokedAt       DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([tenantId])
  @@index([keyHash])
}

model PostTemplate {
  id              String   @id @default(cuid())
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId        String
  name            String
  content         String   @db.Text
  thread          String[] @default([])
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String   // e.g. 'post.created', 'social.account.connected', 'invitation.sent'
  target    String?  // optional id of the affected resource
  payload   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action])
}

model Invitation {
  id              String    @id @default(cuid())
  tenantId        String
  email           String
  role            Role      @default(EDITOR)
  // Hashed sha256 of the raw token; raw token only travels in the email link
  tokenHash       String    @unique
  invitedByUserId String
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([tenantId])
  @@index([email])
}

model Membership {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model SocialAccount {
  id              String         @id @default(cuid())
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId        String
  provider        SocialProvider
  // Provider-side identifier (LinkedIn URN, Facebook page id, IG business id, TikTok open_id…)
  providerUserId  String
  displayName     String?
  avatarUrl       String?
  // Encrypted with TOKEN_ENCRYPTION_KEY (AES-256-GCM)
  accessToken     String
  refreshToken    String?
  expiresAt       DateTime?
  scopes          String?
  // Provider-specific extras (page id, IG business id, …) as JSON
  metadata        Json?
  // Set when token refresh fails or provider returns auth error — UI shows "Reconnect".
  refreshError    String?
  refreshFailedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  postTargets     PostTarget[]

  @@unique([tenantId, provider, providerUserId])
  @@index([tenantId])
}

model Post {
  id            String       @id @default(cuid())
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId      String
  authorUserId  String
  content       String       @db.Text
  // Optional X / Twitter thread — array of subsequent tweets after `content`.
  // Other providers ignore this field.
  thread        String[]     @default([])
  status        PostStatus   @default(DRAFT)
  scheduledAt   DateTime?
  publishedAt   DateTime?

  // Approval workflow metadata
  approvedAt        DateTime?
  approvedByUserId  String?
  rejectedAt        DateTime?
  rejectedByUserId  String?
  rejectionReason   String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  media         MediaAsset[]
  targets       PostTarget[]

  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
}

model PostTarget {
  id              String         @id @default(cuid())
  post            Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId          String
  account         SocialAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId       String
  status          PostStatus     @default(SCHEDULED)
  // Provider-side post id once published (e.g. LinkedIn URN, FB post id)
  providerPostId  String?
  providerUrl     String?
  errorMessage    String?
  attempts        Int            @default(0)
  publishedAt     DateTime?

  metrics         PostMetric[]

  @@unique([postId, accountId])
  @@index([status])
}

// Per-target engagement snapshot. The metrics worker re-fetches at H+1, J+1
// and J+7 after publication, so each row is a point-in-time measurement.
model PostMetric {
  id           String     @id @default(cuid())
  target       PostTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  targetId     String
  fetchedAt    DateTime   @default(now())
  impressions  Int?
  reach        Int?
  likes        Int?
  comments     Int?
  shares       Int?
  clicks       Int?
  // Provider-specific raw numbers we don't model individually.
  raw          Json?

  @@index([targetId, fetchedAt])
}

model MediaAsset {
  id          String   @id @default(cuid())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  post        Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  postId      String?
  filename    String
  mimeType    String
  sizeBytes   Int
  // Local path or S3 key
  storageKey  String
  width       Int?
  height      Int?
  durationSec Int?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([postId])
}

// Outbound webhook subscription. Tenants register a URL + the events they
// care about; the webhook delivery worker POSTs the JSON payload there with
// an HMAC-SHA256 signature in the X-Community-Signature header.
model Webhook {
  id              String             @id @default(cuid())
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId        String
  url             String
  // Used to sign the request body. Shown to the user only once at creation.
  secret          String
  // Subset of: post.published, post.failed, post.scheduled, post.approved,
  // post.rejected, approval.requested. Empty array = no events (effectively disabled).
  events          String[]           @default([])
  active          Boolean            @default(true)
  createdByUserId String
  lastDeliveryAt  DateTime?
  lastFailureAt   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  deliveries      WebhookDelivery[]

  @@index([tenantId])
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  webhookId    String
  event        String
  payload      Json
  // null until delivery is attempted; populated with HTTP code thereafter.
  statusCode   Int?
  responseBody String?
  attempts     Int      @default(0)
  deliveredAt  DateTime?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([webhookId, createdAt])
}

// In-app notification displayed in the bell dropdown. userId may be null for
// tenant-wide notifications (everyone in the tenant sees it).
model Notification {
  id        String    @id @default(cuid())
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  userId    String?
  // e.g. 'post.published', 'post.failed', 'approval.requested'
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId, userId, readAt])
  @@index([tenantId, createdAt])
}
