generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum SubscriptionStatus {
  NONE          // free plan, no Stripe subscription
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum SocialProvider {
  LINKEDIN
  FACEBOOK
  INSTAGRAM
  TIKTOK
  TWITTER
}

enum PostStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

model Tenant {
  id                    String              @id @default(cuid())
  slug                  String              @unique
  name                  String
  plan                  Plan                @default(FREE)
  // Onboarding progress for the tenant
  onboardingCompletedAt DateTime?
  onboardingStep        String              @default("welcome") // welcome | verify | connect | first_post | done

  // Approval workflow — when true, EDITOR-created posts go through PENDING_APPROVAL
  // and require an OWNER/ADMIN to approve before scheduling.
  requireApproval       Boolean             @default(false)

  // Brand voice profile — injected into AI prompts so generated content
  // matches the tenant's tone, vocabulary and constraints.
  brandVoice            Json?

  // White-label theming. logoMediaId references a MediaAsset uploaded via
  // the standard /media endpoint; the public /api/media/:id/raw URL is used
  // as the logo <img src>.
  brandName             String?
  primaryColor          String?
  logoMediaId           String?

  // Stripe billing
  stripeCustomerId      String?             @unique
  stripeSubscriptionId  String?             @unique
  stripePriceId         String?
  subscriptionStatus    SubscriptionStatus  @default(NONE)
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean             @default(false)

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  memberships           Membership[]
  accounts              SocialAccount[]
  posts                 Post[]
  mediaAssets           MediaAsset[]
  templates             PostTemplate[]
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  name               String?
  emailVerifiedAt    DateTime?

  // Two-factor (TOTP). Secret is encrypted with TOKEN_ENCRYPTION_KEY.
  totpSecret         String?
  totpEnabledAt      DateTime?

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  memberships        Membership[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  backupCodes        BackupCode[]
}

model BackupCode {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  // sha256 of the raw code — codes are shown to the user once and never stored.
  codeHash   String    @unique
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  // Hashed token (sha256) — the raw token is sent by email and never stored.
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordReset {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model ApiKey {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  // sha256 of the raw key — the raw apk_… key is shown to the user once,
  // never stored in plaintext.
  keyHash         String    @unique
  // 4-char prefix shown to the user for identification (e.g. "apk_abcd…").
  preview         String
  scopes          String[]  @default(["read", "write"])
  createdByUserId String
  expiresAt       DateTime?
  revokedAt       DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([tenantId])
  @@index([keyHash])
}

model PostTemplate {
  id              String   @id @default(cuid())
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId        String
  name            String
  content         String   @db.Text
  thread          String[] @default([])
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String   // e.g. 'post.created', 'social.account.connected', 'invitation.sent'
  target    String?  // optional id of the affected resource
  payload   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action])
}

model Invitation {
  id              String    @id @default(cuid())
  tenantId        String
  email           String
  role            Role      @default(EDITOR)
  // Hashed sha256 of the raw token; raw token only travels in the email link
  tokenHash       String    @unique
  invitedByUserId String
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([tenantId])
  @@index([email])
}

model Membership {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model SocialAccount {
  id              String         @id @default(cuid())
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId        String
  provider        SocialProvider
  // Provider-side identifier (LinkedIn URN, Facebook page id, IG business id, TikTok open_id…)
  providerUserId  String
  displayName     String?
  avatarUrl       String?
  // Encrypted with TOKEN_ENCRYPTION_KEY (AES-256-GCM)
  accessToken     String
  refreshToken    String?
  expiresAt       DateTime?
  scopes          String?
  // Provider-specific extras (page id, IG business id, …) as JSON
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  postTargets     PostTarget[]

  @@unique([tenantId, provider, providerUserId])
  @@index([tenantId])
}

model Post {
  id            String       @id @default(cuid())
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId      String
  authorUserId  String
  content       String       @db.Text
  // Optional X / Twitter thread — array of subsequent tweets after `content`.
  // Other providers ignore this field.
  thread        String[]     @default([])
  status        PostStatus   @default(DRAFT)
  scheduledAt   DateTime?
  publishedAt   DateTime?

  // Approval workflow metadata
  approvedAt        DateTime?
  approvedByUserId  String?
  rejectedAt        DateTime?
  rejectedByUserId  String?
  rejectionReason   String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  media         MediaAsset[]
  targets       PostTarget[]

  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
}

model PostTarget {
  id              String         @id @default(cuid())
  post            Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId          String
  account         SocialAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId       String
  status          PostStatus     @default(SCHEDULED)
  // Provider-side post id once published (e.g. LinkedIn URN, FB post id)
  providerPostId  String?
  providerUrl     String?
  errorMessage    String?
  attempts        Int            @default(0)
  publishedAt     DateTime?

  @@unique([postId, accountId])
  @@index([status])
}

model MediaAsset {
  id          String   @id @default(cuid())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  post        Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  postId      String?
  filename    String
  mimeType    String
  sizeBytes   Int
  // Local path or S3 key
  storageKey  String
  width       Int?
  height      Int?
  durationSec Int?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([postId])
}
